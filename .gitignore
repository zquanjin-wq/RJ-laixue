# generated data
/data
/logs

# RJ-laixue docs (PRD.md / DEV.md) ARE tracked; OPENMAIC upstream's
# private developer docs live under subdirectories we don't add.
# The blanket /docs ignore was too coarse — it suppressed our hand-off
# documents. If you need to add private notes later, put them under
# docs/internal/ and add that path here instead of reverting this.
/docs/internal/
# Eval results
eval/whiteboard-layout/results/
eval/outline-language/results/
eval/orchestration/results/
eval/orchestration/results-answering/
eval/orchestration/results-answer-content/

# e2e screenshot artifacts
e2e/screenshots/

# local-only sandbox/demo pages (do not ship)
/app/slide-renderer-demo

# local e2e screenshots for #619 review
e2e/__screenshots-619/
/.playwright-mcp/
